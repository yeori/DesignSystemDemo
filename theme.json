{
  "global": {
    "color": {
      "indigo": {
        "50": "#EEF2FF", "100": "#E0E7FF", "200": "#C7D2FE", "300": "#A5B4FC", "400": "#818CF8", 
        "500": "#6366F1", "600": "#4F46E5", "700": "#4338CA", "800": "#3730A3", "900": "#312E81", "950": "#1E1B4B"
      },
      "emerald": {
        "50": "#ECFDF5", "100": "#D1FAE5", "200": "#A7F3D0", "300": "#6EE7B7", "400": "#34D399", 
        "500": "#10B981", "600": "#059669", "700": "#047857", "800": "#065F46", "900": "#064E3B", "950": "#022C22"
      },
      "slate": {
        "50": "#F8FAFC", "100": "#F1F5F9", "200": "#E2E8F0", "300": "#CBD5E1", "400": "#94A3B8", 
        "500": "#64748B", "600": "#475569", "700": "#334155", "800": "#1E293B", "900": "#0F172A", "950": "#020617"
      },
      "red": { "500": "#EF4444" },
      "amber": { "500": "#F59E0B" },
      "sky": { "500": "#0EA5E9" }
    },
    "font": {
      "family": {
        "sans": "Inter, system-ui, -apple-system, sans-serif",
        "mono": "JetBrains Mono, ui-monospace, monospace"
      },
      "size": {
        "xs": "12px", "sm": "14px", "base": "16px", "lg": "18px", "xl": "20px", "2xl": "24px", "3xl": "30px", "4xl": "36px"
      },
      "weight": {
        "regular": "400", "medium": "500", "semibold": "600", "bold": "700", "black": "900"
      },
      "lineHeight": {
        "none": "1", "tight": "1.1", "snug": "1.3", "normal": "1.5", "relaxed": "1.6"
      }
    },
    "spacing": {
      "xs": "4px", "sm": "8px", "md": "16px", "lg": "24px", "xl": "32px", "2xl": "48px", "3xl": "64px"
    },
    "radius": {
      "xs": "2px", "sm": "4px", "md": "6px", "lg": "8px", "xl": "12px", "2xl": "16px", "full": "9999px"
    }
  },
  "alias": {
    "color": {
      "action": {
        "primary": "{global.color.indigo.600}",
        "primaryHover": "{global.color.indigo.700}",
        "primaryGhost": "{global.color.indigo.50}",
        "secondary": "{global.color.emerald.500}",
        "secondaryHover": "{global.color.emerald.600}",
        "secondaryGhost": "{global.color.emerald.50}"
      },
      "text": {
        "main": "{global.color.slate.900}",
        "muted": "{global.color.slate.500}",
        "caption": "{global.color.slate.400}",
        "inverse": "#FFFFFF"
      },
      "bg": {
        "main": "{global.color.slate.50}",
        "card": "#FFFFFF",
        "dark": "{global.color.slate.900}"
      },
      "border": {
        "subtle": "{global.color.slate.100}",
        "regular": "{global.color.slate.200}",
        "focus": "{global.color.indigo.300}"
      },
      "status": {
        "success": "{global.color.emerald.500}",
        "error": "{global.color.red.500}",
        "warning": "{global.color.amber.500}",
        "info": "{global.color.sky.500}"
      }
    },
    "typography": {
      "heading": {
        "xl": { "size": "{global.font.size.4xl}", "weight": "{global.font.weight.bold}", "lh": "{global.font.lineHeight.tight}" },
        "md": { "size": "{global.font.size.xl}", "weight": "{global.font.weight.semibold}", "lh": "{global.font.lineHeight.normal}" }
      },
      "body": {
        "lg": { "size": "{global.font.size.base}", "weight": "{global.font.weight.regular}", "lh": "{global.font.lineHeight.relaxed}" },
        "sm": { "size": "{global.font.size.sm}", "weight": "{global.font.weight.regular}", "lh": "{global.font.lineHeight.normal}" }
      }
    }
  }
}
